#!/bin/sh
# Pre-commit hook — guard against committing stale build bundles.
#
# This hook lives in the repo (.githooks/) so it can be version-controlled.
# Enable it once per clone with:
#
#   git config core.hooksPath .githooks
#
# It blocks a commit when config/config.json or data/ sources are staged but the
# generated bundles (data/scheduleData.json etc.) are not. Bypass with
# `git commit --no-verify` when you intentionally commit sources alone.

node scripts/checkBundleFresh.js
