{
  "name": "KobanCalendar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build-prep",
    "dev": "vite",
    "build": "npm run build-prep && vite build",
    "build-gh-pages": "npm run build-prep && vite build --mode gh-pages",
    "preview": "vite preview",
    "build-prep": "npm run convert-csv && npm run convert-menu",
    "release": "npm run build-prep && npm run build && npm run build-gh-pages",
    "convert-csv": "node scripts/convertCsv.js",
    "convert-menu": "node scripts/convertMenu.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.9",
    "@fullcalendar/interaction": "^6.1.9",
    "@fullcalendar/vue3": "^6.1.9",
    "dayjs": "^1.11.10",
    "japanese-holidays": "^1.0.10",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "vue": "^3.3.7",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.8.9",
    "papaparse": "^5.4.1",
    "prettier": "^3.5.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.2"
  }
}
