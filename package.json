{
  "name": "KobanCalendar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build-prep && vite build",
    "build-gh-pages": "npm run build-prep && vite build --mode gh-pages",
    "preview": "vite preview",
    "build-prep": "npm run convert-csv && npm run convert-menu && npm run create-qr",
    "convert-csv": "node scripts/convertCsv.js",
    "convert-menu": "node scripts/convertMenu.js",
    "create-qr": "node scripts/createQr.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.9",
    "@fullcalendar/interaction": "^6.1.9",
    "@fullcalendar/vue3": "^6.1.9",
    "dayjs": "^1.11.10",
    "japanese-holidays": "^1.0.10",
    "pinia": "^2.1.7",
    "vue": "^3.3.7",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "papaparse": "^5.4.1",
    "prettier": "^3.5.3",
    "qrcode": "^1.5.4",
    "vite": "^6.3.2",
    "vitest": "^4.1.2"
  }
}
